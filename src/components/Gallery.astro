---
interface Props {
  images: string[];
  /** Page path used to build per-image routes, e.g. "/test" → /image/test/0. */
  pagePath: string;
  /** Base alt text; each image is numbered off of it (e.g. "Installations 3"). */
  alt?: string;
}
const { images, pagePath, alt = "Gallery image" } = Astro.props;
const base = pagePath.replace(/^\/+/, "");
---

<div class="mosaic">
  {
    images.map((src, i) => (
      <a
        class="mosaic__tile"
        href={`/image/${base}/${i}`}
        aria-label={`${alt} ${i + 1}`}
      >
        <img
          class="mosaic__img"
          src={src}
          alt={`${alt} ${i + 1}`}
          loading="lazy"
          decoding="async"
          style={`view-transition-name: gallery-${i}`}
        />
      </a>
    ))
  }
</div>

<style>
  .mosaic {
    margin: 0;
    /* Masonry, capped at 3 columns so tiles stay generous (not too wide/dense). */
    columns: 3 14rem;
    column-gap: var(--size-3);
  }

  .mosaic__tile {
    display: block;
    width: 100%;
    margin: 0 0 var(--size-3);
    padding: 0;
    border: 0;
    background: none;
    break-inside: avoid;
    overflow: hidden;
    border-radius: var(--radius-1);
    cursor: zoom-in;
  }

  .mosaic__img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s ease;
  }

  .mosaic__tile:hover .mosaic__img,
  .mosaic__tile:focus-visible .mosaic__img {
    transform: scale(1.03);
  }

  .mosaic__tile:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaic__img {
      transition: none;
    }
  }
</style>
