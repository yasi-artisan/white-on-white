---
import ResponsiveImage from "@/components/ResponsiveImage.astro";
import { GALLERY_SRC_WIDTH, cloudinaryDimensions } from "@/utils/image";

interface Props {
  images: string[];
  /** Page path used to build per-image routes, e.g. "/test" → /image/test/0. */
  pagePath: string;
  /** Base alt text; each image is numbered off of it (e.g. "Installations 3"). */
  alt?: string;
}
const { images, pagePath, alt = "Gallery image" } = Astro.props;
const base = pagePath.replace(/^\/+/, "");
// Intrinsic dims per image (build-time) so each tile reserves its box before
// load — keeps the view-transition snapshot correct on a cold first visit.
const dims = await Promise.all(images.map((s) => cloudinaryDimensions(s)));
// Per-index morph names match the detail view's `gallery-${index}`. The global
// override keeps the resize/position morph but removes the cross-fade — and
// covers back-navigation too, since this is the incoming document on return.
const vtCss = images
  .map(
    (_, i) =>
      `::view-transition-old(gallery-${i}){animation:none;opacity:0}` +
      `::view-transition-new(gallery-${i}){animation:none;opacity:1}`,
  )
  .join("");
---

<div class="mosaic">
  {
    images.map((src, i) => (
      <a
        class="mosaic__tile"
        href={`/image/${base}/${i}`}
        aria-label={`${alt} ${i + 1}`}
      >
        <ResponsiveImage
          class="mosaic__img"
          src={src}
          alt={`${alt} ${i + 1}`}
          width={GALLERY_SRC_WIDTH}
          dims={dims[i]}
          loading="lazy"
          decoding="async"
          style={`view-transition-name: gallery-${i}`}
        />
      </a>
    ))
  }
</div>

<style lang="postcss">
  @import "open-props/media.min.css";

  .mosaic {
    margin: 0;
    width: 100%;
    /* Masonry: 1 column on mobile, 2 on tablet, 3 on desktop. */
    columns: 1;
    column-gap: var(--size-3);
  }

  @media (--sm-n-above) {
    .mosaic {
      columns: 2 14rem;
    }
  }

  @media (--md-n-above) {
    .mosaic {
      columns: 3 14rem;
    }
  }

  .mosaic__tile {
    display: block;
    width: 100%;
    margin: 0 0 var(--size-3);
    padding: 0;
    border: 0;
    background: none;
    break-inside: avoid;
    overflow: hidden;
    border-radius: var(--radius-1);
    cursor: zoom-in;
  }

  /* `:global()` because the <img> is rendered by ResponsiveImage (a child
     component) — Astro's scoped cid wouldn't otherwise reach it. Scoping the
     rule under `.mosaic__tile` (which lives in this template) keeps it contained. */
  .mosaic__tile :global(.mosaic__img) {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s ease;
  }

  .mosaic__tile:hover :global(.mosaic__img),
  .mosaic__tile:focus-visible :global(.mosaic__img) {
    transform: scale(1.03);
  }

  .mosaic__tile:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .mosaic__tile :global(.mosaic__img) {
      transition: none;
    }
  }
</style>

{/* Global so the view-transition pseudo-elements aren't scope-rewritten. */}
<style is:global set:html={vtCss} />
