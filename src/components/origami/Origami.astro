---
// Presentational stage for the origami wireframe animation.
// The animation instance is created and driven by the page (see pages/index.astro).
import { shapes } from "./origami-data";

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="origami" {id}>
  <div class="origami-stage">
    {
      shapes.map((shape, i) =>
        shape.hoverImage ? (
          <img
            class="origami-hover-img"
            data-shape={i}
            src={shape.hoverImage}
            alt={`${shape.label} companion`}
            loading="lazy"
          />
        ) : null,
      )
    }

    <svg
      class="origami-svg"
      viewBox="0 0 1440 1024"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="Origami folding animation"
    >
      <path class="origami-contour" d={shapes[0].contour}></path>
      {
        shapes.map((shape, i) => (
          <g class={`origami-inner origami-inner--${i}`}>
            {shape.polygons.map((d) => (
              <path class="origami-poly" d={d} />
            ))}
          </g>
        ))
      }
    </svg>
  </div>
</div>

<style>
  .origami {
    /* height: 100%; */
    width: 100%;
    display: grid;
    place-items: center;
  }

  .origami-stage {
    position: relative;
    width: 100%;
  }

  .origami-svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    position: relative;
    z-index: 1;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .origami-hover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
    z-index: 0;
  }

  .origami-stage.is-hovering:not(.is-transitioning)
    .origami-hover-img.is-active {
    opacity: 1;
  }

  .origami-stage.is-hovering:not(.is-transitioning) .origami-svg {
    opacity: 0;
  }

  .origami-contour,
  .origami-inner {
    visibility: hidden;
  }

  .origami-contour {
    fill: transparent;
    stroke: #111;
    stroke-width: 4;
    stroke-linecap: square;
    stroke-linejoin: round;
    pointer-events: fill;
    cursor: pointer;
  }

  .origami-poly {
    fill: none;
    stroke: #111;
    stroke-width: 2;
    stroke-linecap: square;
    stroke-linejoin: round;
  }
</style>
