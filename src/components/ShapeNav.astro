---
// Presentational nav of shape buttons. Active/transition state is mirrored
// by the page, which owns the OrigamiAnimation instance.
import { shapes } from "./origami/origami-data";

export interface Props {
  labels?: string[];
  class?: string;
  id: string;
}

const {
  labels = shapes.map((s) => s.label),
  class: extraClass = "",
  id,
} = Astro.props;
---

<nav class={`shape-nav ${extraClass}`} {id}>
  <ul>
    {
      labels.map((label, i) => (
        <li>
          <button
            type="button"
            data-shape-index={i}
            class:list={["shape-nav-btn", { "is-active": i === 0 }]}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {label}
          </button>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .shape-nav {
    --_gap: var(--size-4);
    --_hover-bg: oklch(from var(--orange-2) l c h / 0.5);

    font-family: var(--font-heading);
  }

  .shape-nav ul {
    font-size: var(--size-3);
    font-weight: 600;
    list-style: none;
    display: flex;
    gap: var(--_gap);
    flex-direction: column;
  }

  .shape-nav-btn {
    padding-inline: var(--size-px-3);
    padding-block: var(--size-px-1);
    background: none;
    position: relative;

    letter-spacing: 0.18em;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .shape-nav-btn:hover {
    background: var(--_hover-bg);
  }

  .shape-nav-btn.is-active {
    &::before {
      position: absolute;
      left: -10px;
      content: "▸";
      margin-right: 0.5em;
    }
  }

  .shape-nav-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>
