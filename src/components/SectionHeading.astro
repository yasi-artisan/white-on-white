---
// Dynamic section title. All titles share one grid cell; only the title whose
// index matches the currently-visible origami shape is shown (and is a real
// link to that section's page). The page toggles `.is-active` as shapes morph.
export interface Section {
  label: string;
  href: string;
}

interface Props {
  id: string;
  sections: Section[];
}

const { id, sections } = Astro.props;
---

<header class="section-heading" {id}>
  <div class="heading-stack">
    {
      sections.map((s, i) => (
        <a
          class:list={["heading-link", { "is-active": i === 0 }]}
          data-shape-index={i}
          href={s.href}
        >
          {s.label}
        </a>
      ))
    }
  </div>
</header>

<style lang="postcss">

@import "open-props/media.min.css";
  .section-heading {
    width: 100%;
    display: grid;
    place-items: center;
    text-align: center;
  }

  /* One grid cell shared by every title → they stack and the cell sizes to
     the tallest, so the layout never jumps as the active title changes. */
  .heading-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* mobile: labels hug the left edge */
    width: 100%;
    min-height: 4em;
    gap: 0.8em;
  }

  .heading-link {
    font-size: var(--size-3);
    font-family: var(--font-heading);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-decoration: none;
    color: inherit;

    /* Balanced wrapping + boxing: tidy line breaks, comfortable padding,
       no visible border. */
    display: flex;
    flex-direction: column;
    align-items: flex-start;    /* orange bar hugs the start (left) edge */
    justify-content: flex-end;  /* orange bar sits at the bottom of the link */
    text-align: left;
    text-wrap: balance;
    line-height: 1.3;
    max-width: 15ch;
    padding-inline: 0.35em;

    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.4s ease;

    &::after {
      content: "";
      width: 2px;
      height: 0.6em;            /* short marker for inactive links */
      margin-top: 0.45em;
      background-color: var(--orange-11);
      transform-origin: bottom;
      transition: height 0.4s ease;
    }
  }

  .heading-link.is-active {
    opacity: 1;
    pointer-events: auto;

    &::after {
      height: 2.4em;            /* the current section grows a tall marker */
    }
  }

  .heading-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (--md-n-above) {
    .heading-stack {
      flex-direction: row;
      align-items: flex-end;    /* every bar lands on the same baseline */
      gap: 1em;
    }
  }
</style>
