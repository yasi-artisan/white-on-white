---
export interface Section {
  label: string;
  href: string;
}

interface Props {
  id: string;
  sections: Section[];
}

const { id, sections } = Astro.props;
---

<header class="section-heading" {id}>
  <div class="heading-stack">
    {
      sections.map((s, i) => (
        <a
          class:list={["heading-link", { "is-active": i === 0 }]}
          data-shape-index={i}
          href={s.href}
        >
          {s.label}
        </a>
      ))
    }
  </div>
</header>

<style lang="postcss">
  @import "open-props/media.min.css";

  .section-heading {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .heading-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5em;
  }

  .heading-link {
    font-size: var(--size-3);
    font-family: var(--font-heading);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-decoration: none;
    color: light-dark(var(--gray-9), var(--gray-2));
    text-wrap: balance;
    line-height: 1.3;
    max-width: 15ch;

    opacity: 0.4;
    pointer-events: none;
    transition: opacity var(--morph-duration, 0.4s) cubic-bezier(0.45, 0, 0.55, 1);
  }

  .heading-link.is-active {
    opacity: 1;
    pointer-events: auto;
    font-weight: 600;
  }

  .heading-link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (--md-n-above) {
    .heading-stack {
      flex-direction: row;
      align-items: flex-end;
      justify-content: center;
      gap: 1.25em;
    }
  }
</style>
