---
import type { ChildLink } from "../utils/pages";

export interface Section {
  label: string;
  href: string;
  shape?: string;
  children?: ChildLink[];
}

interface Props {
  id: string;
  sections: Section[];
  /**
   * What the section title does on click.
   * - `"parent"` (default): the title links straight to the section's own
   *   page (`href`). Children are ignored.
   * - `"children"`: the title toggles a popover of child links (when the
   *   section has any). A section without children still falls back to a link.
   */
  mode?: "parent" | "children";
}

const { id, sections, mode = "parent" } = Astro.props;

// Slug a page route the same way the destination page titles its
// `view-transition-name` (see pages/[...path].astro), so a section title
// morphs straight into the page's <h1> on navigation.
const titleVtName = (href: string) =>
  `title-${href.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`;
---

<header class="section-heading" {id}>
  <div class="heading-stack">
    {
      sections.map((s, i) => {
        // Each popover is anchored to its own trigger via a unique anchor name,
        // so it can float beside the title. `popover=auto` makes the group
        // exclusive (only one open) and light-dismissable — native, no JS.
        const anchor = `--${id}-${i}`;
        const panelId = `${id}-panel-${i}`;

        // `children` mode toggles a popover — but only when there are actually
        // children to show; otherwise (and always in `parent` mode) the title
        // is a plain link to the section's own page.
        const children = s.children ?? [];
        const showToggle = mode === "children" && children.length > 0;

        return showToggle ? (
          <div class="section-group">
            <button
              type="button"
              class="section-trigger"
              popovertarget={panelId}
              aria-haspopup="true"
              style={`anchor-name: ${anchor}`}
            >
              <span
                class="title-label"
                style={`view-transition-name: ${titleVtName(s.href)}`}
              >
                {s.label}
              </span>
            </button>
            {/* Child links only — the section's own page is reached via the
                origami, not duplicated here. No background: the list floats in
                the margin beside the titles rather than as a boxed dropdown. */}
            <div
              id={panelId}
              popover="auto"
              class="section-panel"
              style={`position-anchor: ${anchor}`}
            >
              <ul class="child-list">
                {children.map((c) => (
                  <li>
                    {/* The title carries the same view-transition-name as the
                        destination page's <h1> (titleVtName slugs the route the
                        same way), so the link morphs into the page title on
                        click. Closed popovers are display:none, so only the open
                        panel's names are ever live — no duplicates. */}
                    <a href={c.href}>
                      <span
                        class="child-title"
                        style={`view-transition-name: ${titleVtName(c.href)}`}
                      >
                        {c.title}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a class="section-trigger" href={s.href}>
            <span
              class="title-label"
              style={`view-transition-name: ${titleVtName(s.href)}`}
            >
              {s.label}
            </span>
          </a>
        );
      })
    }
  </div>
</header>

<style lang="postcss">
  @import "open-props/media.min.css";

  .section-heading {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .heading-stack {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1.5em;
    width: 100%;
  }

  /* <button> and the childless <a> share this — identical minimal look. The
     button is reset so it reads as plain title text, not a control. */
  .section-trigger {
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: inherit;
    text-align: start;
    cursor: pointer;
    display: block;
    text-decoration: none;
  }
  .section-trigger:focus-visible .title-label {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .title-label {
    display: inline-block;
    font-size: var(--size-3);
    font-family: var(--font-heading);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-wrap: balance;
    line-height: 1.3;
    color: light-dark(var(--gray-9), var(--gray-2));
  }

  .section-trigger:hover .title-label {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  /* The popover floats beside its trigger (anchored to the title's right edge),
     in the empty margin, so — with no box — it never overlaps the stacked
     titles. Top-layer keeps it above the origami and out of layout flow. */
  .section-panel {
    inline-size: max-content;
    max-inline-size: min(22rem, 70vw);
    max-block-size: 40svh;
    overflow-y: auto;

    /* No background, no border — just the floating links. */
    background: none;
    border: none;
    padding: 0;

    opacity: 0;
    translate: -0.3rem 0;
    transition:
      opacity 0.18s ease,
      translate 0.18s ease,
      overlay 0.18s allow-discrete,
      display 0.18s allow-discrete;
  }
  .section-panel:popover-open {
    opacity: 1;
    translate: 0 0;
  }
  @starting-style {
    .section-panel:popover-open {
      opacity: 0;
      translate: -0.3rem 0;
    }
  }

  /* Anchor the flyout beside its trigger — but only where anchor positioning
     exists. Without it, `anchor()` is dropped and `inset:auto` would strand the
     popover at the viewport corner; gating keeps the UA's centered default so
     the panel is always visible. */
  @supports (inset-block-start: anchor(top)) {
    .section-panel {
      inset: auto;
      margin: 0;
      inset-block-end: anchor(top);
      inset-inline-start: anchor(left);
      margin-inline-start: var(--size-4);
    }
  }

  .child-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    /* flex-direction: column; */
    gap: var(--size-3);

    a {
      font-family: var(--font-body);
      font-size: var(--font-size-1);
      line-height: 1.4;
      text-decoration: none;
      color: light-dark(var(--gray-8), var(--gray-3));
      text-wrap: nowrap;
      &:hover {
        text-decoration: underline;
        text-underline-offset: 0.2em;
      }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-panel {
      transition: none;
      translate: 0 0;
    }
  }
</style>
