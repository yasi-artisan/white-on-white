---
//
// Origami.astro — config-driven origami animation
//
// Timeline:
//   1. Draw contour of shape A (3px)
//   2. Stagger-draw inner fold lines of shape A (2px)
//   3. Pause (configurable)
//   4. Reverse-draw inner lines of A, hide them
//   5. Morph contour from shape A → shape B
//   6. Stagger-draw inner fold lines of shape B
//   7. Pause
//   8. Reverse-draw inner lines of B, hide them
//   9. Morph contour B → A … loop
//
// All timing is controlled via OrigamiAnimConfig (see ./origami-data.ts).
import { shapes, defaultConfig, type OrigamiAnimConfig } from "./origami-data";

export interface Props {
  /** Partial overrides for the default animation config. */
  config?: Partial<OrigamiAnimConfig>;
}

const { config: userConfig = {} } = Astro.props;
const cfg: OrigamiAnimConfig = { ...defaultConfig, ...userConfig };

const [shapeA, shapeB] = shapes;

// Serialise the shape contours + config so the client-side script can pick
// them up without an extra network round-trip.
const payload = JSON.stringify({
  contourA: shapeA.contour,
  contourB: shapeB.contour,
  config: cfg,
});
---

<div class="origami" data-origami={payload}>
  <svg
    class="origami-svg"
    viewBox="0 0 1440 1024"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Origami folding animation"
  >
    <!-- Contour — starts as shape A, morphs to B and back -->
    <path class="origami-contour" d={shapeA.contour}></path>

    <!-- Shape A inner fold lines -->
    <g class="origami-inner origami-inner--a">
      {shapeA.polygons.map((d) => <path class="origami-poly" d={d} />)}
    </g>

    <!-- Shape B inner fold lines (hidden until first morph) -->
    <g class="origami-inner origami-inner--b">
      {shapeB.polygons.map((d) => <path class="origami-poly" d={d} />)}
    </g>
  </svg>
</div>

<script>
  import gsap from "gsap";
  import { MorphSVGPlugin } from "gsap/MorphSVGPlugin";
  import { DrawSVGPlugin } from "gsap/DrawSVGPlugin";
  import type { OrigamiAnimConfig } from "./origami-data";

  gsap.registerPlugin(MorphSVGPlugin, DrawSVGPlugin);

  // ------------------------------------------------------------------
  // Parse server-injected data (dataset auto-unescapes HTML entities)
  // ------------------------------------------------------------------
  const root = document.querySelector(".origami") as HTMLElement;
  const raw = JSON.parse(root.dataset.origami ?? "{}");
  const contourA: string = raw.contourA;
  const contourB: string = raw.contourB;
  const cfg: OrigamiAnimConfig = raw.config;

  // ------------------------------------------------------------------
  // DOM references
  // ------------------------------------------------------------------
  const svg = document.querySelector(".origami-svg") as SVGElement;
  const contour = svg.querySelector(".origami-contour") as SVGPathElement;
  const groupA = svg.querySelector(".origami-inner--a") as SVGGElement;
  const groupB = svg.querySelector(".origami-inner--b") as SVGGElement;
  const polysA = gsap.utils.toArray<SVGPathElement>(
    groupA.querySelectorAll(".origami-poly"),
  );
  const polysB = gsap.utils.toArray<SVGPathElement>(
    groupB.querySelectorAll(".origami-poly"),
  );

  // ------------------------------------------------------------------
  // Helper: stagger-draw a set of polygon paths
  // ------------------------------------------------------------------
  function staggerDraw(
    tl: gsap.core.Timeline,
    paths: SVGPathElement[],
    position?: gsap.Position,
  ) {
    tl.fromTo(
      paths,
      { drawSVG: "0 0" },
      {
        drawSVG: "0% 100%",
        duration: cfg.drawDuration,
        stagger: cfg.drawStagger,
        ease: cfg.drawEase,
      },
      position,
    );
  }

  // ------------------------------------------------------------------
  // Helper: reverse-draw then hide a group
  // ------------------------------------------------------------------
  function staggerHide(
    tl: gsap.core.Timeline,
    paths: SVGPathElement[],
    group: SVGGElement,
    position?: gsap.Position,
  ) {
    tl.to(
      paths,
      {
        drawSVG: "0 0",
        duration: cfg.drawDuration * 0.35,
        stagger: { each: cfg.drawStagger * 0.4, from: "end" },
        ease: "power2.in",
      },
      position,
    );
    tl.set(group, { visibility: "hidden" });
  }

  // ------------------------------------------------------------------
  // Build the animation
  // ------------------------------------------------------------------
  function run() {
    const master = gsap.timeline({ defaults: { overwrite: "auto" } });

    // -- Phase 0: set initial visibility ---------------------------------
    master.set([contour, groupA], { visibility: "visible" });
    master.set(groupB, { visibility: "hidden" });

    // -- Phase 1: initial reveal of shape A ------------------------------
    master.fromTo(
      contour,
      { drawSVG: "0 0" },
      {
        drawSVG: "0% 100%",
        duration: cfg.drawDuration * 1.1,
        ease: cfg.drawEase,
      },
    );
    staggerDraw(master, polysA, `-=${cfg.drawDuration * 0.5}`);
    master.to({}, { duration: cfg.pauseAfterDraw });

    // -- Phase 2 → N: repeating A ↔ B loop ------------------------------
    const loop = gsap.timeline({
      repeat: -1,
      repeatDelay: cfg.pauseBetweenCycles,
    });

    // A → B
    staggerHide(loop, polysA, groupA);
    loop.to(contour, {
      morphSVG: { shape: contourB },
      duration: cfg.morphDuration,
      ease: cfg.morphEase,
    });
    loop.set(groupB, { visibility: "visible" });
    staggerDraw(loop, polysB);
    loop.to({}, { duration: cfg.pauseAfterDraw });

    // B → A
    staggerHide(loop, polysB, groupB);
    loop.to(contour, {
      morphSVG: { shape: contourA },
      duration: cfg.morphDuration,
      ease: cfg.morphEase,
    });
    loop.set(groupA, { visibility: "visible" });
    staggerDraw(loop, polysA);
    loop.to({}, { duration: cfg.pauseAfterDraw });

    master.add(loop);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", run);
  } else {
    run();
  }
</script>

<style>
  .origami {
    min-height: 100dvh;
    display: grid;
    place-items: center;
    background: #fff;
  }

  .origami-svg {
    /* Responsive: fill available width up to native artwork size,
       then shrink with the viewport.  height:auto preserves
       the 1440×1024 aspect ratio from viewBox. */
    width: min(100%, 1440px);
    height: auto;
    overflow: visible;
  }

  /* Everything hidden until GSAP takes over */
  .origami-contour,
  .origami-inner {
    visibility: hidden;
  }

  .origami-contour {
    fill: none;
    stroke: #111;
    stroke-width: 3;
    stroke-linecap: square;
    stroke-linejoin: round;
  }

  .origami-poly {
    fill: none;
    stroke: #111;
    stroke-width: 2;
    stroke-linecap: square;
    stroke-linejoin: round;
  }
</style>
