---
import { getEntry } from "astro:content";
import Origami from "../components/origami/Origami.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ShapeScrubber from "../components/ShapeScrubber.astro";
import Layout from "../layouts/Layout.astro";


const settings = await getEntry("settings", "settings");
const sections = settings?.data.landingPageSettings.links ?? [];
---

<Layout>
  <section class="content" data-sections={JSON.stringify(sections)}>
    <Origami id="shape-shifter" items={sections} />
    <SectionHeading id="section-heading" sections={sections} />
    <ShapeScrubber id="shape-scrubber" sections={sections} />
  </section>
</Layout>

<script>
  import { OrigamiAnimation } from "../components/origami/origami-animation";
  import { shapes, defaultConfig } from "../components/origami/origami-data";

  // ClientRouter (View Transitions) runs a bundled <script> only once — on the
  // first page load — so a soft navigation back to / would leave the stage
  // inert. astro:page-load fires on first load AND after every navigation, so we
  // (re)initialise there, guarded by the home page's signature element. The GSAP
  // loop runs `repeat: -1`, so we tear it down on astro:before-swap to keep it
  // from ticking against detached DOM between visits. `sections` is read from a
  // data attribute (serialised from the same settings entry as the markup) so
  // this module stays bundled and cached rather than re-inlined per render.
  let anim: OrigamiAnimation | null = null;

  const initHome = () => {
    const root = document.querySelector<HTMLElement>("#shape-shifter");
    if (!root) return; // not on the home page

    const sectionsEl = root.closest<HTMLElement>("[data-sections]");
    const sections: { label: string; href: string; shape: string }[] =
      sectionsEl ? JSON.parse(sectionsEl.dataset.sections || "[]") : [];

    // Only morph between the shapes the landing page actually enables
    // (settings may be a subset of the full shape set), in section order, so
    // the loop never reaches "phantom" shapes past the last real section.
    const contours = sections
      .map((s) =>
        shapes.find(
          (x) => x.label.trim().toLowerCase() === s.shape.trim().toLowerCase(),
        )?.contour,
      )
      .filter((c): c is string => typeof c === "string");

    // One instance, owned here, driving the stage, heading, and scrubber.
    const instance = new OrigamiAnimation(
      root,
      contours,
      { ...defaultConfig, pauseAfterDraw: 2.5, morphDuration: 2.5 },
    );
    anim = instance;
    instance.startLoop();

    const headingLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>(
        "#section-heading .heading-link",
      ),
    );

    // Share the morph duration with the heading so its crossfade spans the
    // whole transition (consumed in SectionHeading.astro via --morph-duration)
    // instead of finishing early while the contour is still morphing.
    document
      .querySelector<HTMLElement>("#section-heading")
      ?.style.setProperty(
        "--morph-duration",
        `${instance.cfg.morphDuration}s`,
      );
    const scrubber = document.querySelector<HTMLInputElement>(
      "#shape-scrubber .scrubber-input",
    )!;
    const thumb = document.querySelector<SVGSVGElement>(
      "#shape-scrubber .scrubber-thumb",
    )!;

    // Visit the page for whatever shape is currently on screen.
    const goToSection = (index: number) => {
      const href = sections[index]?.href;
      if (href) window.location.href = href;
    };

    // Clicking inside the drawn contour visits the current section's page.
    const contour = document.querySelector<SVGPathElement>(
      "#shape-shifter .origami-contour",
    );
    contour?.addEventListener("click", () => goToSection(instance.currentShape));

    // The slider is a true scrubber: dragging morphs the contour in real time
    // (folds hidden while between shapes); releasing eases onto the nearest
    // stage and only then draws that stage's folds.
    const maxStage = sections.length - 1;
    let dragging = false;

    const placeThumb = (v: number) =>
      thumb.style.setProperty("--pos", String(v));

    scrubber.addEventListener("pointerdown", () => {
      dragging = true;
    });

    scrubber.addEventListener("input", () => {
      const v = Number(scrubber.value);
      placeThumb(v);
      instance.scrubTo(v);
    });

    scrubber.addEventListener("change", () => {
      const releaseValue = Number(scrubber.value);
      const target = Math.max(0, Math.min(maxStage, Math.round(releaseValue)));
      scrubber.value = String(target);
      dragging = false;
      // The pill eases onto `target` via onScrub during the commit — no snap.
      instance.commitScrub(target, releaseValue);
    });

    // Keyboard: arrow keys jump a whole stage (the native 0.01 step is too fine),
    // easing onto each step and drawing its folds.
    scrubber.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      e.preventDefault();
      const fromValue = Math.round(Number(scrubber.value));
      const dir = e.key === "ArrowRight" ? 1 : -1;
      const target = Math.max(0, Math.min(maxStage, fromValue + dir));
      scrubber.value = String(target);
      dragging = false;
      instance.commitScrub(target, fromValue);
    });

    // The thumb follows the scrub position — during the auto-loop's morphs and
    // while a commit eases onto its target. Only the user's own drag drives the
    // thumb directly (via `input`), so leave it alone then. The thumb mirrors
    // whenever the loop is on its return leg (scrub value decreasing); we skip
    // that check during a commit so the ease direction can't trigger a flip.
    let prevScrub = 0;
    instance.onScrub((v) => {
      if (dragging) return;
      placeThumb(v);
      if (instance.isTransitioning) {
        prevScrub = v;
        return;
      }
      if (v < prevScrub - 0.001) thumb.classList.add("is-flipped");
      else if (v > prevScrub + 0.001) thumb.classList.remove("is-flipped");
      prevScrub = v;
    });

    // Discrete: swap the visible heading + keep the input's value baseline
    // correct for keyboard use.
    const sync = () => {
      const current = instance.currentShape;
      for (const link of headingLinks) {
        link.classList.toggle(
          "is-active",
          Number(link.dataset.shapeIndex) === current,
        );
      }
      if (scrubber.value !== String(current))
        scrubber.value = String(current);
    };

    instance.onChange(sync);
  };

  const destroyHome = () => {
    anim?.destroy();
    anim = null;
  };

  document.addEventListener("astro:page-load", initHome);
  document.addEventListener("astro:before-swap", destroyHome);
</script>

<style lang="postcss">
  @import "open-props/media.min.css";

  .content {
    --_width: max(380px, 40dvw);
    max-width: var(--_width);
    display: grid;
    /* flex-direction: column; */
    /* justify-content: center; */
    /* align-items: center; */
    place-content: center;
    justify-content: center;
    place-items: center;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr auto;
    grid-template-areas:
      "origami"
      "heading";
    gap: var(--size-5);
    height: 100%;
    width: 100%;

    #section-heading {
      grid-area: heading;
    }
    #shape-shifter {
      grid-area: origami;
    }
    #shape-scrubber {
      grid-area: origami;
    }
  }

  @media (--md-n-above) {
    .content {
      /* grid-template-columns: 1fr auto;
      grid-template-rows: 1fr;
      grid-template-areas:
        "origami heading"; */
        --_width: max(380px, 60dvw);
    }
  }
</style>
