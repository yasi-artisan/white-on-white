---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Gallery from "@/components/Gallery.astro";
import { inlineMarkdown } from "@/utils/markdown";
import { buildPageTree, type Ancestor, type PageNode } from "@/utils/pages";
import Breadcrumb from "@/components/Breadcrumb.astro";
import ResponsiveImage from "@/components/ResponsiveImage.astro";

// Pages are flat files (title → slug); URL nesting is virtual, derived from each
// page's optional `parent` relation. A chain grandparent → parent → child
// produces /grandparent/parent/child, a breadcrumb, and a sub-page list.
export async function getStaticPaths() {
  const pages = await getCollection("pages", (page) => !page.data.draft);
  const tree = buildPageTree(pages);

  return pages.map((page) => {
    const node = tree.get(page.id)!;
    // Children: published pages that declare this page as their parent.
    // Sorted by this page's configured field (title|subtitle) then order.
    const sortField = (n: PageNode) => {
      const value = page.data.sort?.by === "subtitle" ? n.subtitle : n.title;
      return (value ?? "").toLowerCase();
    };
    const sortDir = (a: PageNode, b: PageNode, dir: number = 1) =>
      sortField(a) < sortField(b) ? -1 * dir : 1 * dir;

    const children = pages
      .filter((p) => p.data.parent === page.id && p.id !== page.id)
      .map((p) => tree.get(p.id)!)
      .sort((a, b) => sortDir(a, b, page.data.sort?.order === "desc" ? -1 : 1))
      .map((n) => ({ title: n.title, href: n.route, subtitle: n.subtitle }));

    return {
      params: { path: node.route.replace(/^\//, "") },
      props: {
        page,
        route: node.route,
        ancestors: node.ancestors,
        children,
      },
    };
  });
}

interface Props {
  page: CollectionEntry<"pages">;
  route: string;
  ancestors: Ancestor[];
  children: { title: string; href: string; subtitle?: string }[];
}

const { page, route, ancestors, children }: Props = Astro.props;
const { Content } = await render(page);
const gallery = page.data.gallery ?? [];
const subtitleHtml = inlineMarkdown(page.data.subtitle);
// `index` pages are listings (children only); `show` pages render their content.
const isShow = page.data.template === "show";
---

<Layout>
  <article class="page">
    <Breadcrumb {ancestors} currentPageTitle={page.data.title} />

    <header class:list={["page__header", { "page__header--show": isShow }]}>
      <h1
        class="page__title"
        style={`view-transition-name: title-${route.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`}
      >
        {page.data.title}
      </h1>
      {
        isShow && subtitleHtml && (
          <div
            class="page__subtitle"
            style={`view-transition-name: subtitle-${route.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`}
            set:html={subtitleHtml}
          />
        )
      }
    </header>

    {
      isShow && gallery.length > 0 && (
        <Gallery images={gallery} pagePath={route} alt={page.data.title} />
      )
    }

    {
      page.data.cover_image && (
        <ResponsiveImage
          class="page__cover"
          src={page.data.cover_image}
          alt={page.data.title}
        />
      )
    }
    <div class="page__body">
      <Content />
    </div>

    {
      children.length > 0 && (
        <nav class="page__children">
          <ul class="page__children-list">
            {children.map((child) => {
              const slug = child.href
                .replace(/^\/|\/$/g, "")
                .replace(/\//g, "-");
              return (
                <li>
                  <a href={child.href}>
                    <span
                      class="child__title"
                      style={`view-transition-name: title-${slug}`}
                    >
                      {child.title}
                    </span>
                    {child.subtitle && (
                      <span
                        class="child__subtitle"
                        style={`view-transition-name: subtitle-${slug}`}
                        set:html={inlineMarkdown(child.subtitle)}
                      />
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      )
    }
  </article>
</Layout>

<style lang="postcss">
  @import "open-props/media.min.css";

  .page {
    padding-block-start: var(--size-7);
    padding-inline: var(--size-3);
    width: 100%;
    max-width: 64rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--size-5);
    align-items: center;

    @media (--sm-n-above) {
      padding-block-start: var(--size-relative-12);
      padding-inline: var(--size-5);
      gap: var(--size-6);
    }

    .page__header {
      display: flex;
      flex-direction: column;
      gap: var(--size-2);
      justify-content: start;
      width: 100%;

      @media (--sm-n-above) {
        flex-direction: row;
        align-items: baseline;
      }

      &.page__header--show {
        justify-content: space-between;

        .page__title {
          text-align: left;
        }
      }

      .page__title {
        margin: 0;
        text-align: center;
        font-weight: 500;
        letter-spacing: 0.15em;
        padding-block: var(--size-3);
        font-family: var(--font-heading);
        font-size: var(--font-size-5);
        line-height: 1.2;

        @media (--sm-n-above) {
          font-size: var(--font-size-7);
        }
      }

      .page__subtitle {
        margin: 0;
        text-align: center;
        font-family: var(--font-body);
        font-size: var(--size-4) !important;
        max-width: 45ch;
        line-height: 1.6;

        @media (--sm-n-above) {
          font-size: var(--font-size-4);
        }
      }
    }

    /* Sibling spacing comes from global heading/paragraph margins
       (global.css); no owl selector — it would flatten the hierarchy. */
    .page__body {
      width: 100%;
      margin-inline: auto;
      font-family: var(--font-body);
      font-size: var(--font-size-1);
      line-height: 1.75;
    }

    .page__children {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--size-3);

      /* fit-content grid: each row is as wide as the widest row; avoids
         display:contents on li, which breaks Chromium view-transition captures. */
      .page__children-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: var(--size-3);
        width: 100%;
        justify-content: start;

        @media (--sm-n-above) {
          justify-content: center;
          align-items: last baseline;
        }

        a {
          display: flex;
          flex-direction: column;
          align-items: baseline;
          gap: 0;
          font-family: var(--font-body);
          font-size: var(--font-size-3);
          text-decoration: none;

          /* title flush left, subtitle flush right, sharing one baseline */
          &:hover {
            text-decoration: underline;
          }

          @media (--sm-n-above) {
            flex-direction: row;
            gap: var(--size-4);
          }

          span {
            font-size: var(--font-size-2);
            color: light-dark(var(--gray-6), var(--gray-6));
          }

          .child__title {
            font-weight: 700;
            color: light-dark(var(--gray-9), var(--gray-2));
          }
        }
      }
    }
  }
</style>
