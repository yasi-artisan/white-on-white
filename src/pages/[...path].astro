---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Gallery from '@/components/Gallery.astro';
import { inlineMarkdown } from '@/utils/markdown';

export async function getStaticPaths() {
  const pages = await getCollection('pages', (page) => !page.data.draft);

  return pages.map((page) => ({
    params: { path: page.data.path },
    props: { page },
  }));
}

interface Props {
  page: CollectionEntry<'pages'>;
}

const { page }: Props = Astro.props;
const { Content } = await render(page);
const gallery = page.data.gallery ?? [];
const subtitleHtml = inlineMarkdown(page.data.subtitle);
---

<Layout>
  <article class="page">
    {subtitleHtml && <span class="page__subtitle" set:html={subtitleHtml} />}
    <h1 class="page__title">{page.data.title}</h1>

    {gallery.length > 0 && <Gallery images={gallery} pagePath={page.data.path} alt={page.data.title} />}

    <div class="page__body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .page {
    padding-block-start: var(--size-relative-12);
    width: 100%;
    max-width: 64rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--size-6);
    align-items: center;
  }

  .page__title {
    margin: 0;
    text-align: center;
    /* uppercase; */
    text-transform: uppercase;
    font-weight: bold;
    letter-spacing: 0.2em;
    padding-block: var(--size-4);
    font-family: var(--font-heading);
    font-size: var(--font-size-7);
  }

  .page__subtitle {
    margin: 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--font-size-4);
  }

  .page__body {
    max-width: 42rem;
    margin-inline: auto;
    font-family: var(--font-body);
  }
</style>
