---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import ResponsiveImage from '@/components/ResponsiveImage.astro';
import { DETAIL_WIDTHS, DETAIL_SIZES, cloudinaryDimensions } from '@/utils/image';
import { buildPageTree } from '@/utils/pages';

export const prerender = true;

// One route per gallery image across all published pages:
//   /image/<page-route>/<index>   e.g. /image/painting/series-a/0
// The route is derived from the page's `parent` chain — matching the catch-all
// route in src/pages/[...path].astro — so it's built from ALL published pages
// (a parent in the chain need not have a gallery itself).
export async function getStaticPaths() {
  const all = await getCollection('pages', (p) => !p.data.draft);
  const tree = buildPageTree(all);
  const pages = all.filter(
    (p) => p.data.template === "show" && (p.data.gallery?.length ?? 0) > 0,
  );

  const routes: {
    params: { slug: string };
    props: { src: string; alt: string; back: string; index: number };
  }[] = [];

  for (const page of pages) {
    const node = tree.get(page.id)!;
    const base = node.route.replace(/^\//, '');
    const images = page.data.gallery ?? [];
    images.forEach((src, i) => {
      routes.push({
        params: { slug: `${base}/${i}` },
        props: {
          src,
          alt: `${page.data.title} ${i + 1}`,
          back: node.route,
          index: i,
        },
      });
    });
  }

  return routes;
}

interface Props {
  src: string;
  alt: string;
  back: string;
  index: number;
}

const { src, alt, back, index } = Astro.props;
// Intrinsic dims (build-time) so the <img> reserves its box before load —
// keeps the view-transition snapshot correct on a cold first visit.
const dims = await cloudinaryDimensions(src);

// Morph name shared with the gallery tile of the same index. The global
// override below hides the outgoing snapshot and pins the incoming one at full
// opacity, so the image resizes + repositions as a single solid frame instead
// of cross-fading into a translucent ghost of itself.
const vtName = `gallery-${index}`;
const vtCss =
  `::view-transition-old(${vtName}){animation:none;opacity:0}` +
  `::view-transition-new(${vtName}){animation:none;opacity:1}`;
---

<Layout>
  <article class="image-view">
    <a class="image-view__back" href={back}>← Back</a>

    <a class="image-view__stage" href={back} aria-label="Close image">
      <ResponsiveImage
        class="image-view__img"
        src={src}
        alt={alt}
        widths={DETAIL_WIDTHS}
        sizes={DETAIL_SIZES}
        dims={dims}
        loading="eager"
        decoding="async"
        style={`view-transition-name: ${vtName}`}
      />
    </a>
  </article>
</Layout>

<script>
  // Escape returns to the gallery; the reverse morph plays automatically.
  // ClientRouter (View Transitions) runs a hoisted <script> only once, so the
  // listener is wired on astro:page-load (fires on first load AND after every
  // navigation) — but only when an image-view page is actually showing — and
  // removed on astro:before-swap so it can't leak onto other pages.
  const onKeydown = (e: KeyboardEvent) => {
    if (e.key === 'Escape') history.back();
  };

  document.addEventListener('astro:page-load', () => {
    if (document.querySelector('.image-view')) {
      document.addEventListener('keydown', onKeydown);
    }
  });
  document.addEventListener('astro:before-swap', () => {
    document.removeEventListener('keydown', onKeydown);
  });
</script>

<style>
  .image-view {
    width: 100%;
    max-width: 60rem;
    margin-inline: auto;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--size-4);
    padding: var(--size-5);
  }

  .image-view__back {
    align-self: flex-start;
    text-decoration: none;
    font-family: var(--font-body);
    color: light-dark(var(--gray-9), var(--gray-3));
  }

  .image-view__stage {
    display: block;
    line-height: 0;
  }

  /* `:global()` — the <img> is rendered by ResponsiveImage (child component),
     so the scoped cid wouldn't reach it. `.image-view__stage` is in this template. */
  .image-view__stage :global(.image-view__img) {
    max-width: 100%;
    max-height: 80dvh;
    object-fit: contain;
    border-radius: var(--radius-2);
  }
</style>

{/* Global so the view-transition pseudo-elements aren't scope-rewritten.
    Active on the forward navigation (this is the incoming document). */}
<style is:global set:html={vtCss} />
