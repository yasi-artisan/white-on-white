---
import Footer from "@/components/footer.astro";
import { ClientRouter } from "astro:transitions";

import { Font } from "astro:assets";
import "@/assets/global.css";
import { getEntry } from "astro:content";

const settings = await getEntry("settings", "settings");
const siteName = settings?.data?.siteName ?? "Yasaman Moussavi";
const menuLinks = settings?.data?.menuLinks ?? [];
const footerLinks = settings?.data?.footerLinks ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <Font cssVariable="--font-satoshi" />
    <Font cssVariable="--font-display" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- <link rel="icon" href="/favicon.ico" /> -->
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{siteName}</title>
  </head>
  <body>
    <aside class="rail" id="site-nav" aria-label="Site navigation">
      {/* Persistent vertical wordmark — the idle indicator and a home link. */}
      <!-- <a class="rail__mark" href="/" aria-label={`${siteName} — home`}>
        {siteName}
      </a> -->
      {
        menuLinks.length > 0 && (
          <nav class="menu" aria-label="Main">
            <ul class="menu__list">
              {menuLinks.map((link) => (
                <li>
                  <a class="menu__link" href={link.url}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </aside>
    <main>
      <slot />
      <Footer title={siteName} links={footerLinks} />
    </main>
  </body>
</html>

<style lang="postcss">
  @import "open-props/media.min.css";

  body {
    overflow-x: clip;
    display: grid;
    grid-template-columns: auto minmax(calc(100% - var(--size-7)), 1fr);
    grid-template-rows: 1fr;
  }

  /* Desktop: hover/focus reveals the menu (--mouse = hover-capable + fine
     pointer). Touch devices get the slide/tap path below instead of a :hover
     that never fires and leaves the menu stuck at opacity:0. */
  @media (--mouse) {
    .rail:hover,
    .rail:focus-within {
      width: min(30ch, 80vw);
    }
  }

  .rail {
    width: var(--size-7);
    transition: width 0.28s ease;
    display: flex;
    align-items: stretch;
    gap: var(--size-3);
    padding-inline: var(--size-2);
    border-right: 1px solid var(--border-color);
    overflow: hidden;
    position: relative;
    max-height: 100vh;
    position: sticky;
    top: 0;

    &::after, &::before {
      content: "";
      position: absolute;
      height: 100%;
    }
    &::after {
      border-right: 1px solid var(--border-color);
      right: 2px;
    }
    &::before {
      border-left: 1px solid var(--border-color);
      right: 5px;
    }
  }

  .rail__mark {
    flex: 0 0 auto;
    align-self: center;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: var(--gray-6);
    font-family: var(--font-heading);
    font-size: var(--font-size-0);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .rail__mark:hover,
  .rail__mark:focus-visible {
    color: light-dark(var(--gray-9), var(--gray-3));
  }

  .menu {
    flex: 0 1 auto;
    min-width: 0;
    width: calc(100% - 8px);
    align-self: center;
    /* Hidden until the rail opens: clipped by overflow, non-interactive. */
    opacity: 0;
    pointer-events: none;
  }

  /* Desktop menu reveal (--mouse). The descendant form is equivalent to the old
     `body:has(.rail:hover, …) .menu` and cheaper. */
  @media (--mouse) {
    .rail:hover .menu,
    .rail:focus-within .menu {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-1);
  }

  .menu__link {
    display: block;
    min-block-size: var(--size-8);
    padding-block: var(--size-2);
    padding-inline: var(--size-3);
    color: inherit;
    height: 100%;
    min-inline-size: var(--size-7);
    text-decoration: none;
    border-radius: var(--radius-1);
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .menu__link:hover {
    background: light-dark(var(--orange-1), var(--gray-8));
    color: light-dark(var(--orange-11), var(--gray-2));
  }

  .menu__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  main {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    margin: 0;
  }

  /* Touch: the rail itself is the handle. Drag it open/closed or tap to toggle
     (see the script below). Widening it pushes <main> off the right edge for
     free via the body grid + overflow-x: clip. The open state is driven by
     html[data-nav-open] (set by JS on tap/drag) and :focus-within (keyboard). */
  @media (--touch) {
    html[data-nav-open] .rail,
    .rail:focus-within {
      width: max(18.75rem, 85vw); /* 300px min, ~85% of the viewport */
    }
    html[data-nav-open] {
      overflow: hidden; /* lock background scroll while the rail is open */
    }
    .rail {
      touch-action: pan-y; /* claim the horizontal drag; let vertical scroll through */
      cursor: ew-resize;
      user-select: none; /* avoid selecting menu text while dragging the rail */
    }
    html[data-nav-open] .rail .menu,
    .rail:focus-within .menu {
      opacity: 1;
      pointer-events: auto;
    }
    /* small top clearance so the first link is reachable when open */
    .rail .menu {
      padding-block-start: var(--size-2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail,
    .menu__link,
    .rail__mark {
      transition: none;
    }
  }
</style>

<script>
  // Gallery → image morph: on a cold first visit the detail image isn't cached
  // when the view transition snapshots the incoming page, and rendering is
  // frozen inside the startViewTransition update callback — so the image can't
  // load/lay out in time, its box renders 0×0, and the tile shrinks to nothing.
  //
  // Fix: preload the destination detail image BEFORE the transition starts.
  // astro:before-preparation runs while the page still renders normally, its
  // `loader` is awaitable, and `newDocument` holds the parsed destination — so
  // we wrap the loader to preload every source (src + srcset) once the HTML is
  // fetched. By swap time the bytes are cached and the new-state snapshot sees
  // the image at full size. The decode-await in the swap is a cheap fallback
  // for an already-complete image.
  const preloadSources = (img: HTMLImageElement) => {
    const urls = new Set<string>();
    const src = img.getAttribute("src");
    if (src) urls.add(src);
    for (const part of (img.getAttribute("srcset") ?? "").split(",")) {
      const url = part.trim().split(/\s+/)[0];
      if (url) urls.add(url);
    }
    return Promise.all(
      [...urls].map(
        (url) =>
          new Promise<void>((resolve) => {
            const pre = new Image();
            pre.decoding = "async";
            pre.onload = () => resolve();
            pre.onerror = () => resolve();
            pre.src = url;
          }),
      ),
    );
  };

  document.addEventListener("astro:before-preparation", (event) => {
    const e = event as unknown as {
      loader: () => Promise<void>;
      newDocument?: Document | null;
    };
    const originalLoader = e.loader;
    e.loader = async () => {
      await originalLoader();
      const img = e.newDocument?.querySelector<HTMLImageElement>(
        "img.image-view__img",
      );
      if (img) await preloadSources(img);
    };
  });

  document.addEventListener("astro:before-swap", (event) => {
    const e = event as unknown as { swap: () => void };
    const originalSwap = e.swap;
    e.swap = async () => {
      originalSwap();
      const img = document.querySelector<HTMLImageElement>("img.image-view__img");
      if (img && !img.complete) {
        await img.decode().catch(() => {});
      }
    };
  });

  // ── Mobile/touch nav: the rail is a slide/tap handle ───────────────
  // On hover-capable pointers the CSS :hover path opens the rail (desktop), so
  // this block no-ops there. On touch (no hover) the rail opens by dragging it
  // or tapping it; widening it pushes <main> off the right edge. Bound on
  // astro:page-load so it survives ClientRouter morphs, deduped via data-bound.
  const NAV_ATTR = "data-nav-open";
  const isTouch = () =>
    window.matchMedia("(hover: none) and (pointer: coarse)").matches;
  const RAIL_COLLAPSED = 32; // var(--size-7) = 2rem
  const railOpenWidthPx = () => Math.max(300, window.innerWidth * 0.85);

  const setNavOpen = (open: boolean) => {
    document.documentElement.toggleAttribute(NAV_ATTR, open);
    // inert gives a focus trap for free (the footer lives in <main> too) and
    // hides the pushed-off content from AT while the rail is open.
    document.querySelector("main")?.toggleAttribute("inert", !open);
  };

  const initNav = () => {
    // Always start closed (defensive against a leftover attribute across navigations).
    document.documentElement.removeAttribute(NAV_ATTR);
    document.querySelector("main")?.removeAttribute("inert");
    if (!isTouch()) return; // desktop uses the CSS hover path

    const rail = document.querySelector<HTMLElement>("#site-nav");
    if (!rail || rail.dataset.bound === "1") return; // morph kept it → skip rebind
    rail.dataset.bound = "1";

    // Tap the strip to toggle; tap a link to navigate + close.
    rail.addEventListener("click", (e) => {
      if ((e.target as Element).closest("a")) setNavOpen(false);
      else setNavOpen(!document.documentElement.hasAttribute(NAV_ATTR));
    });
    document.addEventListener("keydown", (e) => {
      if (
        e.key === "Escape" &&
        document.documentElement.hasAttribute(NAV_ATTR)
      ) {
        setNavOpen(false);
      }
    });

    // Drag the rail open/closed, snapping past the midpoint on release. Track on
    // window (not pointer capture) so a fast drag keeps flowing even if the
    // pointer briefly leaves the rail, and so the subsequent click still targets
    // the element under the finger (e.g. a link) normally.
    let dragging = false;
    let startX = 0;
    let startWidth = 0;
    let moved = false;

    const onPointerMove = (e: PointerEvent) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 6) moved = true;
      else return;
      const width = Math.min(
        Math.max(RAIL_COLLAPSED, startWidth + dx),
        railOpenWidthPx(),
      );
      rail.style.width = `${width}px`;
    };

    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      window.removeEventListener("pointermove", onPointerMove);
      window.removeEventListener("pointerup", endDrag);
      window.removeEventListener("pointercancel", endDrag);
      if (moved) {
        // A drag can synthesize a stray click on the element under the finger —
        // swallow it so a drag ending on a link doesn't navigate.
        const suppress = (ev: Event) => {
          ev.preventDefault();
          ev.stopPropagation();
          rail.removeEventListener("click", suppress, true);
        };
        rail.addEventListener("click", suppress, true);
        const current = rail.getBoundingClientRect().width;
        const midpoint = (RAIL_COLLAPSED + railOpenWidthPx()) / 2;
        const isOpen = document.documentElement.hasAttribute(NAV_ATTR);
        if (current > midpoint && !isOpen) setNavOpen(true);
        else if (current <= midpoint && isOpen) setNavOpen(false);
      }
      rail.style.transition = ""; // restore the CSS width transition
      rail.style.width = ""; // fall back to the stylesheet value → animates
    };

    rail.addEventListener("pointerdown", (e) => {
      if (e.button && e.button !== 0) return; // primary pointer only
      dragging = true;
      moved = false;
      startX = e.clientX;
      startWidth = rail.getBoundingClientRect().width;
      rail.style.transition = "none"; // 1:1 with the finger during the drag
      window.addEventListener("pointermove", onPointerMove);
      window.addEventListener("pointerup", endDrag);
      window.addEventListener("pointercancel", endDrag);
    });
  };

  document.addEventListener("astro:page-load", initNav);
  document.addEventListener("astro:before-swap", () => {
    // Close before the view transition snapshots the outgoing page.
    document.documentElement.removeAttribute(NAV_ATTR);
    document.querySelector("main")?.removeAttribute("inert");
  });
</script>
