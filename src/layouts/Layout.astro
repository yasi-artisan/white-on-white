---
import Footer from "@/components/footer.astro";
import { ClientRouter } from "astro:transitions";

import { Font } from "astro:assets";
import "@/assets/global.css";
import { getEntry } from "astro:content";

const settings = await getEntry("settings", "settings");
const siteName = settings?.data?.siteName ?? "Yasaman Moussavi";
const menuLinks = settings?.data?.menuLinks ?? [];
const footerLinks = settings?.data?.footerLinks ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Font cssVariable="--font-satoshi" />
    <Font cssVariable="--font-display" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- <link rel="icon" href="/favicon.ico" /> -->
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{siteName}</title>
  </head>
  <body>
    <aside class="rail" aria-label="Site navigation">
      {/* Persistent vertical wordmark — the idle indicator and a home link. */}
      <!-- <a class="rail__mark" href="/" aria-label={`${siteName} — home`}>
        {siteName}
      </a> -->
      {
        menuLinks.length > 0 && (
          <nav class="menu" aria-label="Main">
            <ul class="menu__list">
              {menuLinks.map((link) => (
                <li>
                  <a class="menu__link" href={link.url}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </aside>
    <main>
      <slot />
      <Footer title={siteName} links={footerLinks} />
    </main>
  </body>
</html>

<style>
  body {
    overflow-x: clip;
    display: grid;
    grid-template-columns: auto minmax(calc(100% - var(--size-7)), 1fr);
    grid-template-rows: 1fr;
  }

  .rail:hover,
  .rail:focus-within {
    width: min(30ch, 80vw);
  }

  .rail {
    width: var(--size-7);
    transition: width 0.28s ease;
    display: flex;
    align-items: stretch;
    gap: var(--size-3);
    padding-inline: var(--size-2);
    border-right: 1px solid var(--border-color);
    overflow: hidden;
    position: relative;

    &::after, &::before {
      content: "";
      position: absolute;
      height: 100%;
    }
    &::after {
      border-right: 1px solid var(--border-color);
      right: 2px;
    }
    &::before {
      border-left: 1px solid var(--border-color);
      right: 5px;
    }
  }

  .rail__mark {
    flex: 0 0 auto;
    align-self: center;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: var(--gray-6);
    font-family: var(--font-heading);
    font-size: var(--font-size-0);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .rail__mark:hover,
  .rail__mark:focus-visible {
    color: light-dark(var(--gray-9), var(--gray-3));
  }

  .menu {
    flex: 0 1 auto;
    min-width: 0;
    width: calc(100% - 8px);
    align-self: center;
    /* Hidden until the rail opens: clipped by overflow, non-interactive. */
    opacity: 0;
    pointer-events: none;
  }

  body:has(.rail:hover, .rail:focus-within) .menu {
    opacity: 1;
    pointer-events: auto;
  }

  .menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-1);
  }

  .menu__link {
    display: block;
    min-block-size: var(--size-8);
    padding-block: var(--size-2);
    padding-inline: var(--size-3);
    color: inherit;
    height: 100%;
    min-inline-size: var(--size-7);
    text-decoration: none;
    border-radius: var(--radius-1);
    transition: background-color 0.15s ease;
  }

  .menu__link:hover {
    background: light-dark(var(--orange-1), var(--gray-8));
    color: light-dark(var(--orange-11), var(--gray-2));
  }

  .menu__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  main {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .menu__link,
    .rail__mark {
      transition: none;
    }
  }
</style>

<script>
  // Gallery → image morph: the destination <img> can still be decoding when the
  // view transition snapshots the "new" page, which collapses its box and makes
  // it snap in. The View Transitions API awaits the swap callback, so we await
  // the image's decode there — the snapshot is then taken with it laid out.
  document.addEventListener("astro:before-swap", (event) => {
    const e = event as unknown as { swap: () => void };
    const originalSwap = e.swap;
    e.swap = async () => {
      originalSwap();
      const img = document.querySelector<HTMLImageElement>("img.image-view__img");
      if (img && !img.complete) {
        await img.decode().catch(() => {});
      }
    };
  });
</script>
