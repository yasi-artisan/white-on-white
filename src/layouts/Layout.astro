---
import Footer from "@/components/footer.astro";
import { ClientRouter } from "astro:transitions";

import { Font } from "astro:assets";
import "@/assets/global.css";
import { getEntry } from "astro:content";

const settings = await getEntry("settings", "settings");
const siteName = settings?.data?.siteName ?? "Yasaman Moussavi";
const menuLinks = settings?.data?.menuLinks ?? [];
const footerLinks = settings?.data?.footerLinks ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <Font cssVariable="--font-satoshi" />
    <Font cssVariable="--font-display" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- <link rel="icon" href="/favicon.ico" /> -->
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>{siteName}</title>
  </head>
  <body>
    <aside class="rail" id="site-nav" aria-label="Site navigation">
      {/* Tap affordance for touch: 3-line grip that fades out once open. */}
      <div class="rail__grip" aria-hidden="true"></div>
      {
        menuLinks.length > 0 && (
          <nav class="menu" aria-label="Main">
            <ul class="menu__list">
              {menuLinks.map((link) => (
                <li>
                  <a class="menu__link" href={link.url}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </aside>
    <main>
      <div class="overlay"></div>
      <slot />
      <Footer title={siteName} links={footerLinks} />
    </main>
  </body>
</html>

<style lang="postcss">
  @import "open-props/media.min.css";

  body {
    overflow-x: clip;
    display: grid;
    grid-template-columns: auto minmax(calc(100% - var(--size-7)), 1fr);
    grid-template-rows: 1fr;
  }

  main {
    position: relative;
  }

  .overlay {
    display: none;
  }

  /* Desktop: a click toggles the rail open (data-nav-open); :focus-within
     covers keyboard. No :hover opening. --mouse = hover-capable + fine pointer. */
  @media (--mouse) {
    .rail:focus-within,
    html[data-nav-open] .rail {
      width: min(30ch, 80vw);

      & ~ main > .overlay {
        display: block;
        inset: 0;
        z-index: 100;
        backdrop-filter: blur(2px);
        background: rgba(0, 0, 0, 0.2);
        position:absolute;
      }
    }
  }


  .rail {
    width: var(--size-7);
    transition: width 0.28s ease;
    display: flex;
    align-items: stretch;
    gap: var(--size-3);
    padding-inline: var(--size-2);
    border-right: 1px solid var(--border-color);
    overflow: hidden;
    position: relative;
    position: sticky;
    top: 0;
    align-self: start; /* stretched grid items can't stick */
    height: 100dvh;

    &::after, &::before {
      content: "";
      position: absolute;
      height: 100%;
    }
    &::after {
      border-right: 1px solid var(--border-color);
      right: 2px;
    }
    &::before {
      border-left: 1px solid var(--border-color);
      right: 5px;
    }
  }

  /* Tap affordance for touch. Three hairlines via layered gradients, centered.
     pointer-events:none so the tap lands on the rail (which toggles). Hidden by
     default; the --touch block below shows it and fades it once the drawer opens. */
  .rail__grip {
    position: absolute;
    inset: 0;
    width: 1.4rem;
    height: 0.5rem;
    margin: auto;
    pointer-events: none;
    display: none;
    color: light-dark(var(--gray-4), var(--gray-7));
    background:
      linear-gradient(currentColor, currentColor) center top / 100% 1px no-repeat,
      linear-gradient(currentColor, currentColor) center / 100% 1px no-repeat,
      linear-gradient(currentColor, currentColor) center bottom / 100% 1px no-repeat;
    rotate: 90deg;
    transition: opacity 0.2s ease;
  }

  .rail__mark {
    flex: 0 0 auto;
    align-self: center;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: var(--gray-6);
    font-family: var(--font-heading);
    font-size: var(--font-size-0);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .rail__mark:hover,
  .rail__mark:focus-visible {
    color: light-dark(var(--gray-9), var(--gray-3));
  }

  .menu {
    flex: 0 1 auto;
    min-width: 0;
    width: calc(100% - 8px);
    align-self: center;
    /* Hidden until the rail opens: clipped by overflow, non-interactive. */
    opacity: 0;
    pointer-events: none;
  }

  /* Desktop menu reveal (--mouse) — on click-pin or keyboard focus. */
  @media (--mouse) {
    .rail:focus-within .menu,
    html[data-nav-open] .rail .menu {
      opacity: 1;
      pointer-events: auto;
    }
  }

  .menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-1);
  }

  .menu__link {
    display: block;
    min-block-size: var(--size-8);
    padding-block: var(--size-2);
    padding-inline: var(--size-3);
    color: inherit;
    height: 100%;
    min-inline-size: var(--size-7);
    text-decoration: none;
    border-radius: var(--radius-1);
    transition: background-color 0.15s ease;
    white-space: nowrap;
  }

  .menu__link:hover {
    background: light-dark(var(--orange-1), var(--gray-8));
    color: light-dark(var(--orange-11), var(--gray-2));
  }

  .menu__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: -2px;
  }

  main {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    margin: 0;
  }

  /* Scroll lock on open — <html> ONLY. overflow:hidden on <body> would make
     body a scroll container and defeat the rail's position:sticky (the rail
     un-pins and snaps to its document position, so opening mid-scroll shows a
     slice of the menu instead of its top at the window). <html> holds the
     viewport scrollbar, so locking it is enough; scrollbar-gutter: stable
     (global.css) keeps the gutter reserved so the lock can't shift the page. */
  html[data-nav-open] {
    overflow: hidden;
  }

  /* Touch: tap the rail to toggle. Widening it pushes <main> off the right edge
     for free via the body grid + overflow-x: clip. The open state is driven by
     html[data-nav-open] (set by JS on tap) and :focus-within (keyboard). */
  @media (--touch) {
    html[data-nav-open] .rail,
    .rail:focus-within {
      width: min(18.75rem, 85vw);
    }
    .rail {
      touch-action: manipulation; /* snappy taps, no double-tap-zoom, scroll still works */
    }
    .rail__grip {
      display: block; /* reveal the tap affordance only on touch pointers */
    }
    html[data-nav-open] .rail__grip {
      opacity: 0; /* menu is visible — hide the grip */
    }
    html[data-nav-open] .rail .menu,
    .rail:focus-within .menu {
      opacity: 1;
      pointer-events: auto;
    }
    /* small top clearance so the first link is reachable when open */
    .rail .menu {
      padding-block-start: var(--size-2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rail,
    .menu__link,
    .rail__mark,
    .rail__grip {
      transition: none;
    }
  }
</style>

<script>
  // Gallery → image morph: on a cold first visit the detail image isn't cached
  // when the view transition snapshots the incoming page, and rendering is
  // frozen inside the startViewTransition update callback — so the image can't
  // load/lay out in time, its box renders 0×0, and the tile shrinks to nothing.
  //
  // Fix: preload the destination detail image BEFORE the transition starts.
  // astro:before-preparation runs while the page still renders normally, its
  // `loader` is awaitable, and `newDocument` holds the parsed destination — so
  // we wrap the loader to preload every source (src + srcset) once the HTML is
  // fetched. By swap time the bytes are cached and the new-state snapshot sees
  // the image at full size. The decode-await in the swap is a cheap fallback
  // for an already-complete image.
  const preloadSources = (img: HTMLImageElement) => {
    const urls = new Set<string>();
    const src = img.getAttribute("src");
    if (src) urls.add(src);
    for (const part of (img.getAttribute("srcset") ?? "").split(",")) {
      const url = part.trim().split(/\s+/)[0];
      if (url) urls.add(url);
    }
    return Promise.all(
      [...urls].map(
        (url) =>
          new Promise<void>((resolve) => {
            const pre = new Image();
            pre.decoding = "async";
            pre.onload = () => resolve();
            pre.onerror = () => resolve();
            pre.src = url;
          }),
      ),
    );
  };

  document.addEventListener("astro:before-preparation", (event) => {
    const e = event as unknown as {
      loader: () => Promise<void>;
      newDocument?: Document | null;
    };
    const originalLoader = e.loader;
    e.loader = async () => {
      await originalLoader();
      const img = e.newDocument?.querySelector<HTMLImageElement>(
        "img.image-view__img",
      );
      if (img) await preloadSources(img);
    };
  });

  document.addEventListener("astro:before-swap", (event) => {
    const e = event as unknown as { swap: () => void };
    const originalSwap = e.swap;
    e.swap = async () => {
      originalSwap();
      const img = document.querySelector<HTMLImageElement>(
        "img.image-view__img",
      );
      if (img && !img.complete) {
        await img.decode().catch(() => {});
      }
    };
  });

  // ── Nav: click/tap the rail to toggle (pins open) ──────────────────
  // Binds on every pointer. A click on the rail pins it open via data-nav-open
  // (the CSS then widens it, shows the overlay, and locks scroll); a click on a
  // link navigates + closes; Escape closes. On desktop the :hover peek still
  // works without pinning. Bound on astro:page-load so it survives ClientRouter
  // morphs, deduped via data-bound.
  const NAV_ATTR = "data-nav-open";

  const setNavOpen = (open: boolean) => {
    document.documentElement.toggleAttribute(NAV_ATTR, open);
    // inert gives a focus trap for free (the footer lives in <main> too) and
    // hides the pushed-off content from AT while the rail is open.
    document.querySelector("main")?.toggleAttribute("inert", !open);
  };

  const initNav = () => {
    // Always start closed (defensive against a leftover attribute across navigations).
    document.documentElement.removeAttribute(NAV_ATTR);
    document.querySelector("main")?.removeAttribute("inert");

    const rail = document.querySelector<HTMLElement>("#site-nav");
    if (!rail || rail.dataset.bound === "1") return; // morph kept it → skip rebind
    rail.dataset.bound = "1";

    // Click the rail to toggle; click a link to navigate + close.
    rail.addEventListener("click", (e) => {
      if ((e.target as Element).closest("a")) setNavOpen(false);
      else setNavOpen(!document.documentElement.hasAttribute(NAV_ATTR));
    });
    document.addEventListener("keydown", (e) => {
      if (
        e.key === "Escape" &&
        document.documentElement.hasAttribute(NAV_ATTR)
      ) {
        setNavOpen(false);
      }
    });
  };

  document.addEventListener("astro:page-load", initNav);
  document.addEventListener("astro:before-swap", () => {
    // Close before the view transition snapshots the outgoing page.
    document.documentElement.removeAttribute(NAV_ATTR);
    document.querySelector("main")?.removeAttribute("inert");
  });
</script>
